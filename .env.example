# 环境变量配置
# 使用方法：cp .env.example .env 然后修改下方配置

# 数据库路径（容器内路径，无需修改）
DATABASE_URL="file:/app/data/prod.db"

# JWT密钥（生产环境必须修改为随机字符串）
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# 管理员账户
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""

# IP访问限制（留空允许所有IP）
ADMIN_IP_WHITELIST=""

# 系统配置
NODE_ENV=production
PORT=3000
NEXT_TELEMETRY_DISABLED=1 