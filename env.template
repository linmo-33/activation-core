# 环境变量配置模板
# 使用方法：复制此文件为 .env 并根据需要修改配置

# 数据库配置
DATABASE_URL="file:./dev.db"

# JWT密钥（生产环境请使用强随机密钥）
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# 管理员账户配置（可选，如不设置则使用默认值）
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""  # 留空将自动生成随机密码

# IP白名单配置（可选，逗号分隔多个IP，留空允许所有IP访问）
ADMIN_IP_WHITELIST="127.0.0.1,::1"  # localhost访问，生产环境请设置具体IP

# 应用环境
NODE_ENV="development"

# 可选：自定义端口（默认3000）
# PORT=3000

# 可选：数据库日志（development环境默认开启）
# DATABASE_LOG_ENABLED=true

# ==================== 配置说明 ====================
# 
# DATABASE_URL: SQLite数据库文件路径
#   - 开发环境：file:./dev.db
#   - 生产环境：建议使用绝对路径，如 file:/var/app/data/prod.db
#
# JWT_SECRET: JWT令牌签名密钥
#   - 开发环境：可使用默认值
#   - 生产环境：必须使用强随机密钥，建议32字符以上
#   - 生成方法：openssl rand -base64 32
#
# ADMIN_USERNAME: 管理员用户名
#   - 默认：admin
#   - 建议：生产环境使用复杂用户名
#
# ADMIN_PASSWORD: 管理员密码
#   - 留空：系统自动生成随机密码
#   - 设置值：使用指定密码（建议8位以上包含数字字母符号）
#
# ADMIN_IP_WHITELIST: 管理后台IP白名单
#   - 留空：允许所有IP访问（不推荐生产环境）
#   - 单个IP：127.0.0.1
#   - 多个IP：127.0.0.1,192.168.1.100,::1
#   - 支持IPv4和IPv6格式
#
# NODE_ENV: 应用运行环境
#   - development: 开发环境
#   - production: 生产环境
#   - test: 测试环境 